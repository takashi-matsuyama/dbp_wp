  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expr-eval-fork": "^3.0.3"
  },
  "devDependencies": {
    "tsup": "^8.3.0"
  }
}
