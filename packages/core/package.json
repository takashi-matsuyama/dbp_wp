{
  "name": "@dbp-wp/core",
  "version": "0.0.0",
  "description": "Core library for DBP WP: WordPress REST client, formula engine, importer, and typesetting data generation.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
