{
  "name": "@dbp-wp/ui",
  "version": "0.2.15",
  "description": "DBP WP web UI: table view and spreadsheet (Svelte 5 SPA). Served by the dbp-wp CLI.",
  "license": "Apache-2.0",
  "author": "Takashi Matsuyama",
  "homepage": "https://wp.dbp.jp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takashi-matsuyama/dbp_wp.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/takashi-matsuyama/dbp_wp/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./dist/*": "./dist/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "seed:demo": "node scripts/build-demo-seed.mjs",
    "preview": "vite preview",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@dbp-wp/core": "0.2.15",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tanstack/table-core": "^8.20.5",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "vite": "^5.4.0"
  }
}
