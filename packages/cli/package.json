{
  "name": "dbp-wp",
  "version": "0.2.10",
  "description": "Local-first app to bulk-edit WordPress content over the REST API. Runs via npx: starts a localhost server, serves the web UI, and opens your browser.",
  "license": "Apache-2.0",
  "author": "Takashi Matsuyama",
  "homepage": "https://wp.dbp.jp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takashi-matsuyama/dbp_wp.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/takashi-matsuyama/dbp_wp/issues"
  },
  "keywords": [
    "wordpress",
    "wordpress-rest-api",
    "bulk-edit",
    "spreadsheet",
    "cli"
  ],
  "type": "module",
  "bin": {
    "dbp-wp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@dbp-wp/core": "0.2.10",
    "@dbp-wp/ui": "0.2.10"
  },
  "devDependencies": {
    "tsup": "^8.3.0"
  }
}
